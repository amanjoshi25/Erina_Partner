# FastAPI Backend Configuration Variables
PROJECT_NAME="Erina Assistance Platform"

# PostgreSQL Database Configuration
# If running PostgreSQL natively on your mac, update these credentials to match your local setup.
# If running via docker-compose, use the defaults below.
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=erina_admin
POSTGRES_PASSWORD=erina_secure_password
POSTGRES_DB=erina_db

# Security
SECRET_KEY=super_secret_temporary_key_for_dev_change_me_in_prod
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 Days
